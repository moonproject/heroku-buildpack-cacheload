#!/usr/bin/env bash

set -e # fail fast


indent() {
  sed -u 's/^/       /'
}


# Resolve a cached path to its source (in cache dir) and destination (in build
# dir or home dir).  Sets SRC and DEST variables.
resolve_paths() {
  local filename=$1
  if [[ ${filename} = \~/* ]]; then
    local without_tilde=${filename#\~/}
    SRC="${CACHE_DIR}/buildcache/${HOME_FOLDER_REPLACEMENT}/${without_tilde}"
    DEST="${HOME}/${without_tilde}"
  else
    SRC="${CACHE_DIR}/buildcache/${filename}"
    DEST="${BUILD_DIR}/${filename}"
  fi
}


# Copy a single file or directory from cache to build dir.  Output is emitted
# as a single line so it stays readable when many restores run in parallel.
restore_path() {
  local filename=$1
  resolve_paths "${filename}"

  # skip non-existing files
  if ! [ -e "${SRC}" ]; then
    echo "${filename} ✗ - not found" | indent
    return
  fi

  # create parent directory structure
  mkdir -p "$(dirname "${DEST}")"

  # delete old files
  if [ -e "${DEST}" ]; then
    rm -r "${DEST}"
  fi

  # copy files from cache
  cp -r "${SRC}" "${DEST}"

  echo "${filename} ✓" | indent
}


# Test whether a collected path matches a negation pattern.  Matching is done
# entirely in memory (no filesystem scan) so it stays fast regardless of how
# large the cache is.  Supports shell globs (*, ?, []) and a leading "**/" to
# match at any depth, plus a trailing "/" to mean "directory path only".
matches_pattern() {
  local path=$1
  local pattern=$2

  # Trailing slash – treat as the directory path itself.
  pattern="${pattern%/}"

  # Direct glob match (bash extended pattern matching).
  [[ "${path}" == ${pattern} ]] && return 0

  # "**/<rest>" matches <rest> at the root or at any depth.
  if [[ "${pattern}" == \*\*/* ]]; then
    local rest="${pattern#\*\*/}"
    [[ "${path}" == ${rest} ]] && return 0
    [[ "${path}" == */${rest} ]] && return 0
  fi

  return 1
}


BUILD_DIR=$1
CACHE_DIR=$2
HOME_FOLDER_REPLACEMENT="__CACHE_HOME__"


echo "=====> Restoring files from cache"

# Collect the final set of paths to restore.  Inclusion lines are literal
# file/folder paths that are added directly (no cache scan needed – cp -r
# handles directory recursion at restore time).  Negation lines (starting with
# !) support glob patterns and remove any already-collected paths that match.
# Order matters – just like .gitignore, later rules override earlier ones.

# Use an associative array to track included paths (value "1" = included).
declare -A RESTORE_SET

while IFS= read -r line || [[ -n "${line}" ]]; do
  # Strip leading/trailing whitespace.
  line="$(echo "${line}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

  # Skip empty lines and comments.
  [[ -z "${line}" ]] && continue
  [[ "${line}" == \#* ]] && continue

  if [[ "${line}" == \!* ]]; then
    # Negation – remove matching paths from the restore set using in-memory
    # glob matching against the already-collected paths.
    local_pattern="${line#!}"
    # Strip whitespace again after removing !
    local_pattern="$(echo "${local_pattern}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [[ -z "${local_pattern}" ]] && continue
    for collected in "${!RESTORE_SET[@]}"; do
      if matches_pattern "${collected}" "${local_pattern}"; then
        unset RESTORE_SET["${collected}"]
      fi
    done
  else
    # Inclusion – add the literal file/folder path to the restore set.  A
    # trailing slash is normalised away; restore_path copies it recursively.
    line="${line%/}"
    [[ -n "${line}" ]] && RESTORE_SET["${line}"]=1
  fi
done < "${BUILD_DIR}/.buildcache"

# Restore all collected paths.  Copying is done in parallel to speed up the
# restore – each path is independent, so we run several copies concurrently
# while capping the number of background jobs to avoid overloading the dyno.
MAX_JOBS="$( (command -v nproc >/dev/null 2>&1 && nproc) || echo 4)"
[[ "${MAX_JOBS}" =~ ^[0-9]+$ ]] && [ "${MAX_JOBS}" -ge 1 ] || MAX_JOBS=4

for FILENAME in "${!RESTORE_SET[@]}"; do
  restore_path "${FILENAME}" &

  # Throttle: wait for a job to finish once we hit the concurrency limit.
  while [ "$(jobs -p | wc -l)" -ge "${MAX_JOBS}" ]; do
    wait -n 2>/dev/null || wait
  done
done

# Wait for any remaining background copies to complete.
wait
