#!/usr/bin/env bash

set -e # fail fast


indent() {
  sed -u 's/^/       /'
}


# Resolve a cached path to its source (in cache dir) and destination (in build
# dir or home dir).  Sets SRC and DEST variables.
resolve_paths() {
  local filename=$1
  if [[ ${filename} = \~/* ]]; then
    local without_tilde=${filename#\~/}
    SRC="${CACHE_DIR}/buildcache/${HOME_FOLDER_REPLACEMENT}/${without_tilde}"
    DEST="${HOME}/${without_tilde}"
  else
    SRC="${CACHE_DIR}/buildcache/${filename}"
    DEST="${BUILD_DIR}/${filename}"
  fi
}


# Copy a single file or directory from cache to build dir.  Output is emitted
# as a single line so it stays readable when many restores run in parallel.
restore_path() {
  local filename=$1
  resolve_paths "${filename}"

  # skip non-existing files
  if ! [ -e "${SRC}" ]; then
    echo "${filename} ✗ - not found" | indent
    return
  fi

  # create parent directory structure
  mkdir -p "$(dirname "${DEST}")"

  # delete old files
  if [ -e "${DEST}" ]; then
    rm -r "${DEST}"
  fi

  # copy files from cache
  cp -r "${SRC}" "${DEST}"

  echo "${filename} ✓" | indent
}


# Test whether a collected path matches a negation pattern.  Matching is done
# entirely in memory (no filesystem scan) so it stays fast regardless of how
# large the cache is.  Supports shell globs (*, ?, []) and a leading "**/" to
# match at any depth, plus a trailing "/" to mean "directory path only".
matches_pattern() {
  local path=$1
  local pattern=$2

  # Trailing slash – treat as the directory path itself.
  pattern="${pattern%/}"

  # Direct glob match (bash extended pattern matching).
  [[ "${path}" == ${pattern} ]] && return 0

  # "**/<rest>" matches <rest> at the root or at any depth.
  if [[ "${pattern}" == \*\*/* ]]; then
    local rest="${pattern#\*\*/}"
    [[ "${path}" == ${rest} ]] && return 0
    [[ "${path}" == */${rest} ]] && return 0
  fi

  return 1
}


# Return success if the pattern contains shell glob metacharacters.
is_glob() {
  local p=$1
  [[ "${p}" == *'*'* || "${p}" == *'?'* || "${p}" == *'['* ]]
}


# Remove a single negation target.  Deletes the path both from the build dir
# (so the current build doesn't see it) and from the cache dir (so it is not
# reloaded on future builds).  Honours NEG_DIR_ONLY (a trailing slash that
# means "directories only").  Echoes nothing; sets REMOVED=true when anything
# was deleted.
remove_negation_target() {
  local build_target=$1
  local cache_target=$2
  local path
  for path in "${build_target}" "${cache_target}"; do
    [ -e "${path}" ] || continue
    if ${NEG_DIR_ONLY} && ! [ -d "${path}" ]; then
      continue
    fi
    rm -r "${path}"
    REMOVED=true
  done
}


# Resolve where a negation pattern applies: sets NEG_ROOT (the filesystem root
# the pattern is relative to), NEG_CACHE_ROOT (the matching root inside the
# cache dir), NEG_SUB (the pattern without any ~/ prefix or trailing slash) and
# NEG_DIR_ONLY (true when a trailing slash means it should only match
# directories).
resolve_negation() {
  local pattern=$1
  NEG_DIR_ONLY=false
  if [[ ${pattern} = \~/* ]]; then
    NEG_ROOT="${HOME}"
    NEG_CACHE_ROOT="${CACHE_DIR}/buildcache/${HOME_FOLDER_REPLACEMENT}"
    NEG_SUB="${pattern#\~/}"
  else
    NEG_ROOT="${BUILD_DIR}"
    NEG_CACHE_ROOT="${CACHE_DIR}/buildcache"
    NEG_SUB="${pattern}"
  fi
  if [[ "${NEG_SUB}" == */ ]]; then
    NEG_DIR_ONLY=true
    NEG_SUB="${NEG_SUB%/}"
  fi
}


# Remove a literal (non-glob) negation directly – no filesystem scan required,
# which keeps things fast when there are many cached paths.  The path is purged
# from both the build dir and the cache dir.
remove_literal_negation() {
  local pattern=$1
  resolve_negation "${pattern}"
  REMOVED=false
  remove_negation_target "${NEG_ROOT}/${NEG_SUB}" "${NEG_CACHE_ROOT}/${NEG_SUB}"
  ${REMOVED} && echo "! ${pattern} ✓ removed" | indent
}


# Remove a glob negation by matching it against the paths that were actually
# restored (passed in as relative paths, one per argument after the pattern).
# Only restored paths are considered, so a negation can never delete files that
# were not loaded from cache.  Matching paths are purged from both the build dir
# and the cache dir, so old cache files are cleaned up instead of being reloaded
# on every build.
remove_glob_negation() {
  local pattern=$1
  shift
  resolve_negation "${pattern}"
  local rel
  REMOVED=false
  for rel in "$@"; do
    matches_pattern "${rel}" "${NEG_SUB}" || continue
    remove_negation_target "${NEG_ROOT}/${rel}" "${NEG_CACHE_ROOT}/${rel}"
  done
  ${REMOVED} && echo "! ${pattern} ✓ removed" | indent
}


BUILD_DIR=$1
CACHE_DIR=$2
HOME_FOLDER_REPLACEMENT="__CACHE_HOME__"


echo "=====> Restoring files from cache"

# Collect the set of paths to restore and the list of negations to apply.
# Inclusion lines are literal file/folder paths added directly (no cache scan –
# cp -r handles directory recursion at restore time).  Negation lines (starting
# with !) may be literal paths, directories or glob patterns; they are applied
# AFTER restoring, by removing matching paths from the restored tree.  In our
# use cases there are far fewer negations than inclusions, so the heavier
# pattern handling only runs over the small negation set.

# Use an associative array to track included paths (value "1" = included) and an
# ordered list to track negations.
declare -A RESTORE_SET
NEGATIONS=()

while IFS= read -r line || [[ -n "${line}" ]]; do
  # Strip leading/trailing whitespace.
  line="$(echo "${line}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

  # Skip empty lines and comments.
  [[ -z "${line}" ]] && continue
  [[ "${line}" == \#* ]] && continue

  if [[ "${line}" == \!* ]]; then
    # Negation – record the pattern; it is applied after restoring.
    local_pattern="${line#!}"
    # Strip whitespace again after removing !
    local_pattern="$(echo "${local_pattern}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [[ -n "${local_pattern}" ]] && NEGATIONS+=("${local_pattern}")
  else
    # Inclusion – add the literal file/folder path to the restore set.  A
    # trailing slash is normalised away; restore_path copies it recursively.
    line="${line%/}"
    [[ -n "${line}" ]] && RESTORE_SET["${line}"]=1
  fi
done < "${BUILD_DIR}/.buildcache"

# Restore all collected paths.  Copying is done in parallel to speed up the
# restore – each path is independent, so we run several copies concurrently
# while capping the number of background jobs to avoid overloading the dyno.
MAX_JOBS="$( (command -v nproc >/dev/null 2>&1 && nproc) || echo 4)"
[[ "${MAX_JOBS}" =~ ^[0-9]+$ ]] && [ "${MAX_JOBS}" -ge 1 ] || MAX_JOBS=4

for FILENAME in "${!RESTORE_SET[@]}"; do
  restore_path "${FILENAME}" &

  # Throttle: wait for a job to finish once we hit the concurrency limit.
  while [ "$(jobs -p | wc -l)" -ge "${MAX_JOBS}" ]; do
    wait -n 2>/dev/null || wait
  done
done

# Wait for any remaining background copies to complete.
wait

# Apply negations against the restored tree.  Literal negations are removed
# directly; glob negations are matched only against paths that were actually
# restored, so they can never delete files that weren't loaded from cache.
if [ "${#NEGATIONS[@]}" -gt 0 ]; then
  GLOB_NEGATIONS=()
  for PATTERN in "${NEGATIONS[@]}"; do
    if is_glob "${PATTERN}"; then
      GLOB_NEGATIONS+=("${PATTERN}")
    else
      remove_literal_negation "${PATTERN}"
    fi
  done

  # Glob negations need the list of restored paths.  Build it once by walking
  # only the restored positive subtrees (after literal negations have run).
  if [ "${#GLOB_NEGATIONS[@]}" -gt 0 ]; then
    BUILD_PATHS=()
    HOME_PATHS=()
    for FILENAME in "${!RESTORE_SET[@]}"; do
      resolve_paths "${FILENAME}"
      [ -e "${DEST}" ] || continue
      if [[ ${FILENAME} = \~/* ]]; then
        while IFS= read -r f; do HOME_PATHS+=("${f#${HOME}/}"); done < <(find "${DEST}")
      else
        while IFS= read -r f; do BUILD_PATHS+=("${f#${BUILD_DIR}/}"); done < <(find "${DEST}")
      fi
    done

    for PATTERN in "${GLOB_NEGATIONS[@]}"; do
      if [[ ${PATTERN} = \~/* ]]; then
        remove_glob_negation "${PATTERN}" "${HOME_PATHS[@]}"
      else
        remove_glob_negation "${PATTERN}" "${BUILD_PATHS[@]}"
      fi
    done
  fi
fi
